{
  "installCommand": "cd frontend && npm install",
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/[...path].py": {
      "maxDuration": 60,
      "includeFiles": "backend/context/**"
    }
  },
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/[...path].py"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
